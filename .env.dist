# ReleaseHub Server Environment Variables Template
# Copy this file to '.env' and fill in your values.

# Port to listen on (default: 4000)
PORT=4000

# Directory for persistent data (database + uploads).
# Default: parent of dist/ folder (works for local dev).
# When running via Docker, this is set to /app/data automatically by docker-compose.yml.
# DATA_DIR=/app/data
